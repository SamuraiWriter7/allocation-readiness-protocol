{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/allocation-blocking-rule-set.schema.json",
  "title": "Allocation Blocking Rule Set",
  "description": "A machine-readable rule set for determining which readiness conditions block, defer, dispute, or reject progression toward royalty allocation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "allocation_blocking_rule_set"
  ],
  "properties": {
    "allocation_blocking_rule_set": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_type",
        "rule_set_id",
        "created_at",
        "target_record_type",
        "resolution_policy",
        "default_behavior",
        "rules"
      ],
      "properties": {
        "schema_version": {
          "const": "0.2.0"
        },
        "record_type": {
          "const": "allocation_blocking_rule_set"
        },
        "rule_set_id": {
          "type": "string",
          "pattern": "^abrs-[a-z0-9][a-z0-9-]{2,63}$"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "target_record_type": {
          "const": "allocation_readiness_record"
        },
        "resolution_policy": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "strategy",
            "decision_precedence",
            "stop_after_terminal_rule"
          ],
          "properties": {
            "strategy": {
              "enum": [
                "most_restrictive_decision",
                "highest_priority_first"
              ]
            },
            "decision_precedence": {
              "const": [
                "rejected",
                "disputed",
                "blocked",
                "pending_review",
                "ready"
              ]
            },
            "stop_after_terminal_rule": {
              "type": "boolean"
            }
          }
        },
        "default_behavior": {
          "enum": [
            "preserve_existing_decision",
            "pending_review"
          ]
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/blockingRule"
          }
        }
      }
    }
  },
  "$defs": {
    "condition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "field",
        "operator",
        "values"
      ],
      "properties": {
        "field": {
          "enum": [
            "origin_status",
            "derivative_status",
            "contribution_status",
            "audit_status",
            "identity_status",
            "license_status",
            "human_review_status",
            "dispute_status"
          ]
        },
        "operator": {
          "enum": [
            "equals",
            "not_equals",
            "in"
          ]
        },
        "values": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "verified",
              "unverified",
              "pending",
              "not_applicable",
              "resolved",
              "unresolved",
              "assessed",
              "unassessed",
              "passed",
              "failed",
              "bound",
              "unbound",
              "permitted",
              "restricted",
              "unknown",
              "completed",
              "required",
              "not_required",
              "none",
              "open",
              "rejected"
            ]
          }
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_status",
        "issue_code",
        "severity",
        "message",
        "requires_human_review",
        "terminal"
      ],
      "properties": {
        "decision_status": {
          "enum": [
            "pending_review",
            "blocked",
            "disputed",
            "rejected"
          ]
        },
        "issue_code": {
          "enum": [
            "unverified_origin",
            "unresolved_derivative",
            "contribution_unassessed",
            "audit_failed",
            "identity_unbound",
            "license_unknown",
            "license_restricted",
            "human_review_required",
            "open_dispute",
            "missing_evidence",
            "other"
          ]
        },
        "severity": {
          "enum": [
            "warning",
            "blocking"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "requires_human_review": {
          "type": "boolean"
        },
        "terminal": {
          "type": "boolean"
        }
      }
    },
    "remediation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed"
      ],
      "properties": {
        "allowed": {
          "type": "boolean"
        },
        "next_action": {
          "enum": [
            "verify_origin",
            "resolve_derivative",
            "assess_contribution",
            "rerun_audit",
            "bind_identity",
            "clarify_license",
            "complete_human_review",
            "resolve_dispute",
            "provide_evidence",
            "manual_review"
          ]
        },
        "required_evidence": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "allowed": {
                "const": true
              }
            },
            "required": [
              "allowed"
            ]
          },
          "then": {
            "required": [
              "next_action"
            ]
          }
        }
      ]
    },
    "blockingRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "enabled",
        "priority",
        "title",
        "description",
        "match",
        "conditions",
        "action",
        "remediation"
      ],
      "properties": {
        "rule_id": {
          "type": "string",
          "pattern": "^abr-[a-z0-9][a-z0-9-]{2,63}$"
        },
        "enabled": {
          "type": "boolean"
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "match": {
          "enum": [
            "all",
            "any"
          ]
        },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/condition"
          }
        },
        "action": {
          "$ref": "#/$defs/action"
        },
        "remediation": {
          "$ref": "#/$defs/remediation"
        }
      }
    }
  }
}
