{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/allocation-readiness-record.schema.json",
  "title": "Allocation Readiness Record",
  "description": "A machine-readable record for determining whether an audited value trace is ready to proceed toward royalty allocation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "allocation_readiness_record"
  ],
  "properties": {
    "allocation_readiness_record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "record_type",
        "readiness_id",
        "created_at",
        "subject",
        "checks",
        "decision",
        "blocking_issues"
      ],
      "properties": {
        "schema_version": {
          "const": "0.1.0"
        },
        "record_type": {
          "const": "allocation_readiness_record"
        },
        "readiness_id": {
          "type": "string",
          "pattern": "^arr-[a-z0-9][a-z0-9-]{2,63}$"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "subject": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "subject_id",
            "subject_type",
            "refs"
          ],
          "properties": {
            "subject_id": {
              "type": "string",
              "minLength": 1
            },
            "subject_type": {
              "enum": [
                "trace_bundle",
                "origin_claim",
                "derivative_record",
                "contribution_bundle",
                "composite_case"
              ]
            },
            "refs": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "trace_receipt_refs": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "origin_claim_ref": {
                  "type": "string",
                  "minLength": 1
                },
                "derivative_record_refs": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "contribution_record_refs": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "audit_record_refs": {
                  "type": "array",
                  "minItems": 1,
                  "uniqueItems": true,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              },
              "anyOf": [
                {
                  "required": [
                    "trace_receipt_refs"
                  ]
                },
                {
                  "required": [
                    "origin_claim_ref"
                  ]
                },
                {
                  "required": [
                    "derivative_record_refs"
                  ]
                },
                {
                  "required": [
                    "contribution_record_refs"
                  ]
                },
                {
                  "required": [
                    "audit_record_refs"
                  ]
                }
              ]
            }
          }
        },
        "checks": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "origin_status",
            "derivative_status",
            "contribution_status",
            "audit_status",
            "identity_status",
            "license_status",
            "human_review_status",
            "dispute_status"
          ],
          "properties": {
            "origin_status": {
              "enum": [
                "verified",
                "unverified",
                "pending",
                "not_applicable"
              ]
            },
            "derivative_status": {
              "enum": [
                "resolved",
                "unresolved",
                "pending",
                "not_applicable"
              ]
            },
            "contribution_status": {
              "enum": [
                "assessed",
                "unassessed",
                "pending",
                "not_applicable"
              ]
            },
            "audit_status": {
              "enum": [
                "passed",
                "failed",
                "pending"
              ]
            },
            "identity_status": {
              "enum": [
                "bound",
                "unbound",
                "pending",
                "not_applicable"
              ]
            },
            "license_status": {
              "enum": [
                "permitted",
                "restricted",
                "unknown",
                "not_applicable"
              ]
            },
            "human_review_status": {
              "enum": [
                "completed",
                "required",
                "pending",
                "not_required"
              ]
            },
            "dispute_status": {
              "enum": [
                "none",
                "open",
                "resolved",
                "rejected"
              ]
            }
          }
        },
        "decision": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "reason",
            "decided_by",
            "decision_at"
          ],
          "properties": {
            "status": {
              "enum": [
                "ready",
                "pending_review",
                "blocked",
                "disputed",
                "rejected"
              ]
            },
            "reason": {
              "type": "string",
              "minLength": 1
            },
            "decided_by": {
              "enum": [
                "protocol_rule",
                "human_reviewer",
                "multi_wing_review"
              ]
            },
            "decision_at": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        "blocking_issues": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "code",
              "severity",
              "message"
            ],
            "properties": {
              "code": {
                "enum": [
                  "unverified_origin",
                  "unresolved_derivative",
                  "contribution_unassessed",
                  "audit_failed",
                  "identity_unbound",
                  "license_unknown",
                  "license_restricted",
                  "human_review_required",
                  "open_dispute",
                  "missing_evidence",
                  "other"
                ]
              },
              "severity": {
                "enum": [
                  "warning",
                  "blocking"
                ]
              },
              "message": {
                "type": "string",
                "minLength": 1
              },
              "ref": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "notes": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "decision": {
                "properties": {
                  "status": {
                    "const": "ready"
                  }
                },
                "required": [
                  "status"
                ]
              }
            },
            "required": [
              "decision"
            ]
          },
          "then": {
            "properties": {
              "checks": {
                "properties": {
                  "origin_status": {
                    "enum": [
                      "verified",
                      "not_applicable"
                    ]
                  },
                  "derivative_status": {
                    "enum": [
                      "resolved",
                      "not_applicable"
                    ]
                  },
                  "contribution_status": {
                    "enum": [
                      "assessed",
                      "not_applicable"
                    ]
                  },
                  "audit_status": {
                    "const": "passed"
                  },
                  "identity_status": {
                    "enum": [
                      "bound",
                      "not_applicable"
                    ]
                  },
                  "license_status": {
                    "enum": [
                      "permitted",
                      "not_applicable"
                    ]
                  },
                  "human_review_status": {
                    "enum": [
                      "completed",
                      "not_required"
                    ]
                  },
                  "dispute_status": {
                    "enum": [
                      "none",
                      "resolved",
                      "rejected"
                    ]
                  }
                }
              },
              "blocking_issues": {
                "maxItems": 0
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "checks": {
                "properties": {
                  "dispute_status": {
                    "const": "open"
                  }
                },
                "required": [
                  "dispute_status"
                ]
              }
            },
            "required": [
              "checks"
            ]
          },
          "then": {
            "properties": {
              "decision": {
                "properties": {
                  "status": {
                    "enum": [
                      "disputed",
                      "blocked"
                    ]
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "checks": {
                "properties": {
                  "human_review_status": {
                    "enum": [
                      "required",
                      "pending"
                    ]
                  }
                },
                "required": [
                  "human_review_status"
                ]
              }
            },
            "required": [
              "checks"
            ]
          },
          "then": {
            "properties": {
              "decision": {
                "properties": {
                  "status": {
                    "enum": [
                      "pending_review",
                      "blocked"
                    ]
                  }
                }
              }
            }
          }
        }
      ]
    }
  }
}
